---
const { className } = Astro.props
---

<div class={className}>
  <h1 class="mb-2 text-base font-extrabold tracking-[0.08em] uppercase">
    Education
  </h1>
  <div class="w-full border-[3px] border-foreground bg-background px-3 py-2 font-mono">
    <div class="flex flex-col gap-1 text-xs sm:flex-row sm:items-center sm:justify-between sm:text-sm">
      <div class="font-bold">
        The NorthCap University - B.Tech (CSE)
      </div>
      <div class="font-bold sm:text-right">2022 - 2026</div>
    </div>
  </div>
</div>
