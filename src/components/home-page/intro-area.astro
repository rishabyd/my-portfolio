---
interface Props {
  className?: string
}

const { className } = Astro.props
---

<div class={`gap-5 font-mono lg:flex ${className || ""}`}>
  <div class="w-full">
    <h1 class="text-3xl leading-none font-black tracking-tight uppercase sm:text-4xl lg:text-5xl">
      Rishab Yadav
    </h1>

    <p class="mt-3 max-w-xl text-base leading-relaxed font-medium sm:text-lg">
      I build things, write about ideas, and watch films most people haven't heard of.
    </p>
  </div>
</div>
