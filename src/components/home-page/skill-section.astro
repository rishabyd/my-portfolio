---
interface Props {
  className?: string
}

const { className } = Astro.props
---

<div class={className}>
  <h1 class="mb-2 text-lg font-bold lg:text-start lg:text-xl">
    Skills
  </h1>
  <div class="w-full border-[5px] border-foreground px-3 py-2 font-mono">
    <p class="text-xs font-bold tracking-wide uppercase sm:text-sm">
      React • Next.js • TypeScript • PostgreSQL
    </p>
  </div>
</div>
