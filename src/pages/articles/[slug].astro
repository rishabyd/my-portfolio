---
import Layout from "@/layouts/main.astro"
import { getCollection, render } from "astro:content"

export async function getStaticPaths() {
  const articles = await getCollection("articles")
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }))
}

const { article } = Astro.props
const { Content } = await render(article)
const formattedDate = article.data.publishDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
})
---

<Layout title={`${article.data.title} | Rishab Yadav`}>
  <div class="flex h-full w-full justify-center">
    <main
      class="flex w-full flex-col gap-8 px-4 pt-14 sm:gap-10 lg:w-2xl lg:px-0 lg:pt-18"
    >
      <a
        href="/archive"
        class="self-start font-mono text-xs font-black uppercase hover:bg-foreground hover:text-background sm:text-base"
      >
        &lt;= ARCHIVE
      </a>
      <article class="rounded-none border-[5px] border-foreground p-5 sm:p-10 lg:p-12">
        <header class="mb-8">
          <div class="mb-4 font-mono text-xs text-foreground/50">
            <span class="animate-pulse">&gt; </span>
            <span>FILE: {article.id}</span>
            <span class="ml-4">// {formattedDate}</span>
          </div>
          <h1 class="mb-2 font-black uppercase tracking-tight sm:text-3xl">
            {article.data.title}
          </h1>
          {article.data.tags && article.data.tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {article.data.tags.map((tag: string) => (
                <span class="font-mono text-xs font-bold uppercase text-foreground/70">
                  [#{tag}]
                </span>
              ))}
            </div>
          )}
          <div class="mt-6 h-[3px] w-full bg-foreground"></div>
        </header>
        <div class="prose-brutalist">
          <Content />
        </div>
        <div class="mt-8 font-mono text-xs text-foreground/40">
          <span>// END OF FILE</span>
          <span class="ml-4 animate-pulse">_</span>
        </div>
      </article>
    </main>
  </div>
</Layout>
