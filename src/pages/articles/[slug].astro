---
import Layout from "@/layouts/main.astro"
import { getCollection, render } from "astro:content"

export async function getStaticPaths() {
  const articles = await getCollection("articles")
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }))
}

const { article } = Astro.props
const { Content } = await render(article)
const formattedDate = article.data.publishDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
})
---

<Layout title={`${article.data.title} | Rishab Yadav`}>
  <div class="flex min-h-screen w-full items-center justify-center p-4 sm:p-6">
    <main class="flex w-full max-w-[44rem] flex-col gap-6 sm:gap-8">
      <a
        href="/archive"
        class="self-start whitespace-nowrap border-[3px] border-foreground px-[0.72rem] py-[0.5rem] text-[0.72rem] leading-none font-black tracking-[0.08em] uppercase transition-none hover:bg-foreground hover:text-background sm:px-[0.82rem] sm:py-[0.58rem] sm:text-[0.82rem]"
      >
        &lt;= ARCHIVE
      </a>
      <article class="border-[3px] border-foreground bg-background p-5 sm:p-10 lg:p-12">
        <header class="mb-8">
          <div class="mb-4 font-mono text-[0.82rem] leading-none font-bold tracking-[0.08em] uppercase">
            <span>&gt; </span>
            <span>FILE: {article.id}</span>
            <span class="ml-4">// {formattedDate}</span>
          </div>
          <h1 class="mb-2 text-[clamp(1.9rem,4.4vw,2.9rem)] leading-none font-black tracking-[0.08em] uppercase">
            {article.data.title}
          </h1>
          {article.data.tags && article.data.tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {article.data.tags.map((tag) => (
                <span class="border-2 border-foreground px-2 py-1 font-mono text-[0.82rem] leading-none font-bold tracking-[0.08em] uppercase">
                  [#{tag}]
                </span>
              ))}
            </div>
          )}
          <div class="mt-6 h-[3px] w-full bg-foreground"></div>
        </header>
        <div class="prose-brutalist">
          <Content />
        </div>
        <div class="mt-8 font-mono text-[0.82rem] leading-none font-bold tracking-[0.08em] uppercase">
          <span>// END OF FILE</span>
          <span class="ml-4">_</span>
        </div>
      </article>
    </main>
  </div>
</Layout>
