---
import Layout from "@/layouts/main.astro";
import Header from "@/components/header.astro";
import { getCollection } from "astro:content";

const allArticles = await getCollection("articles", ({ data }) => !data.draft);
const sortedArticles = allArticles.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);

const articleData = sortedArticles.map((article) => ({
  slug: article.id,
  title: article.data.title,
  description: article.data.description,
  publishDate: article.data.publishDate.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  }),
}));
---

<Layout title="Rishab Yadav | Writing">
  <div class="min-h-dvh p-6 sm:p-12">
    <main class="mx-auto max-w-2xl">
      <Header />

      <div class="space-y-6">
        {articleData.length === 0 ? (
          <div>
            <p class="text-muted-foreground">Coming soon.</p>
            <p class="text-sm text-muted-foreground mt-2">
              Articles on programming, technology, and ideas I'm thinking about.
            </p>
          </div>
        ) : (
          articleData.map((article) => (
            <article>
              <a href={`/writing/${article.slug}`} class="block p-3 -mx-3 hover:bg-white hover:text-black">
                <h2 class="text-lg font-medium">
                  {article.title}
                </h2>
                <p class="text-sm text-muted-foreground mt-1">
                  {article.description}
                </p>
                <time class="text-xs text-muted-foreground mt-2 block">
                  {article.publishDate}
                </time>
              </a>
            </article>
          ))
        )}
      </div>

      <p class="text-xs text-muted-foreground mt-8">
        {articleData.length} article{articleData.length !== 1 ? "s" : ""}
      </p>
    </main>
  </div>
</Layout>