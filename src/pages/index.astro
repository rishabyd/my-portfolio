---
import Layout from "@/layouts/main.astro";
import Header from "@/components/header.astro";
---

<Layout title="Rishab Yadav">
    <div class="min-h-dvh p-6 sm:p-12">
        <main class="mx-auto max-w-2xl">
            <Header />

            <section class="sm:mt-24">
                <h1 class="text-3xl font-normal tracking-tight">
                    Rishab Yadav
                </h1>
                <p class="mt-3 text-muted-foreground">
                    Building <a
                        href="https://github.com/braxiushq/cipher"
                        target="_blank"
                        class="hover:underline font-bold">Cipher</a
                    > at <a
                        href="https://github.com/braxiushq"
                        target="_blank"
                        class="hover:underline font-bold">Braxius</a
                    >. I write about ideas and occasionally watch films.
                </p>
<p class="mt-3 text-muted-foreground">
          Currently working with React, Next.js, and TypeScript, building things with PostgreSQL. I studied Computer Science at The NorthCap University.
        </p>
        <p class="mt-3 text-muted-foreground font-bold">Open to work.</p>
            </section>
        </main>
    </div>
</Layout>
