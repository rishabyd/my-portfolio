---
import Layout from "@/layouts/main.astro"
import IntroArea from "@/components/home-page/intro-area.astro"
import Education from "@/components/home-page/education-section.astro"
import SkillsArea from "@/components/home-page/skill-section.astro"
---

<Layout title="Rishab Yadav | Personal Site">
  <div class="flex h-dvh min-h-dvh w-full items-center justify-center overflow-hidden p-4 sm:p-6">
    <main class="flex w-full max-w-[44rem] flex-col gap-6 sm:gap-8">
      <section
        id="archive-entry"
        class="flex items-center justify-between gap-2 border-[3px] border-foreground bg-background p-[0.72rem] sm:gap-3 sm:p-[0.95rem]"
      >
        <a
          href="/archive"
          class="shrink-0 whitespace-nowrap border-[3px] border-foreground px-[0.72rem] py-[0.5rem] text-[0.72rem] leading-none font-black tracking-[0.08em] uppercase transition-none hover:bg-foreground hover:text-background sm:px-[0.82rem] sm:py-[0.58rem] sm:text-[0.82rem]"
        >
          ARCHIVE
        </a>
        <div class="flex min-w-0 flex-nowrap items-center justify-end gap-1 sm:gap-2">
          <!-- GITHUB TEXT LINK -->
          <a
            href="https://github.com/rishabyd"
            target="_blank"
            class="shrink-0 whitespace-nowrap border-[3px] border-foreground px-[0.72rem] py-[0.5rem] text-[0.72rem] leading-none font-black tracking-[0.08em] uppercase transition-none hover:bg-foreground hover:text-background sm:px-[0.82rem] sm:py-[0.58rem] sm:text-[0.82rem]"
          >
            GITHUB
          </a>

          <a
            href="https://x.com/rishabyd"
            target="_blank"
            class="shrink-0 whitespace-nowrap border-[3px] border-foreground px-[0.72rem] py-[0.5rem] text-[0.72rem] leading-none font-black tracking-[0.08em] uppercase transition-none hover:bg-foreground hover:text-background sm:px-[0.82rem] sm:py-[0.58rem] sm:text-[0.82rem]"
          >
            X
          </a>

          <a
            href="https://codeberg.org/rishabyd"
            target="_blank"
            class="shrink-0 whitespace-nowrap border-[3px] border-foreground px-[0.72rem] py-[0.5rem] text-[0.72rem] leading-none font-black tracking-[0.08em] uppercase transition-none hover:bg-foreground hover:text-background sm:px-[0.82rem] sm:py-[0.58rem] sm:text-[0.82rem]"
          >
            CODEBERG
          </a>

          <!-- EMAIL BUTTON -->
          <a
            href="mailto:rishabyd47@gmail.com"
            class="shrink-0 whitespace-nowrap border-[3px] border-foreground px-[0.72rem] py-[0.5rem] text-[0.72rem] leading-none font-black tracking-[0.08em] uppercase transition-none hover:bg-foreground hover:text-background sm:px-[0.82rem] sm:py-[0.58rem] sm:text-[0.82rem]"
          >
            EMAIL
          </a>
        </div>
      </section>
      <section
        id="about"
        class="flex flex-col gap-8 border-[3px] border-foreground bg-background p-5 sm:gap-10 sm:p-10 lg:p-12"
      >
        <IntroArea />

        <div class="h-[3px] w-full bg-foreground"></div>

        <SkillsArea />

        <div class="h-[3px] w-full bg-foreground"></div>

        <Education />
      </section>
    </main>
  </div>
</Layout>
